{
  "name": "orders-api-copilot-pt3",
  "version": "1.0.0",
  "description": "Orders Management REST API with pagination, filtering, seed data, tests, and Copilot metrics report.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "seed": "node src/seed.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand"
  },
  "keywords": ["orders", "api", "pagination", "filtering", "copilot"],
  "author": "Maks Sh",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
